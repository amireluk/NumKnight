{
  "name": "numknight",
  "private": true,
  "version": "1.3.159",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/bump-version.js && vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "build:dev": "node scripts/bump-version.js && VITE_BASE=/NumKnight/dev/ vite build",
    "deploy:dev": "npm run build:dev && gh-pages -d dist -b gh-pages --dest dev --add"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  }
}
